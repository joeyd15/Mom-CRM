# ─────────────────────────────────────────────────────────────────────────────
# Real Estate AI Lead Hub — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, Vercel Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Admin Authentication ──────────────────────────────────────────────────────
# Password to log into the /admin dashboard
ADMIN_PASSWORD=change-me-to-something-strong

# Your admin email (shown in some UI elements)
ADMIN_EMAIL=you@yourdomain.com

# Secret for signing session cookies (random 32+ character string)
SESSION_SECRET=change-me-to-a-random-32-character-string

# App URL (used for redirects and webhook URLs in production)
NEXTAUTH_URL=https://your-app.vercel.app

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Set to true to skip real OpenAI calls and use mock responses
USE_MOCK_OPENAI=false

# ── Follow Up Boss ────────────────────────────────────────────────────────────
# Get from: Follow Up Boss → Admin → API → Create API Key
# Zillow leads come through FUB (no separate Zillow key needed)
FOLLOW_UP_BOSS_API_KEY=

# Optional: For partner integrations (usually leave blank)
FOLLOW_UP_BOSS_X_SYSTEM=
FOLLOW_UP_BOSS_X_SYSTEM_KEY=

# ── Twilio SMS ────────────────────────────────────────────────────────────────
# Get from: twilio.com/console
# SMS sending is controlled by SEND_MODE below — disabled by default
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Resend Email ──────────────────────────────────────────────────────────────
# Get from: resend.com
# Email sending is controlled by SEND_MODE below — disabled by default
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=agent@yourdomain.com

# ── Message Send Mode ─────────────────────────────────────────────────────────
# IMPORTANT: Start with "disabled" and test before enabling anything
# disabled       — No messages sent, drafts saved for review only (DEFAULT)
# manual_approval — Admin must approve each message before sending
# auto_send       — Messages sent automatically (use only after thorough testing)
SEND_MODE=disabled

# ── Meta / Facebook / Instagram ───────────────────────────────────────────────
# Get from: developers.facebook.com
# All campaigns require admin approval before launch
# Real estate ads use Special Ad Category = HOUSING (auto-applied)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_IG_BUSINESS_ID=
META_WEBHOOK_VERIFY_TOKEN=generate-a-random-token-here
META_API_VERSION=v19.0

# ── Cron Job Security ─────────────────────────────────────────────────────────
# Vercel automatically sends this as Bearer token for cron jobs
# Generate a random string and also add it in Vercel dashboard
CRON_SECRET=generate-a-random-secret-here

# ── Legacy / BoldTrail / MAXTech ─────────────────────────────────────────────
MAXTECH_API_BASE_URL=
MAXTECH_API_KEY=
ZAPIER_WEBHOOK_URL=
